rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth.uid != null;
    }

    function isViewer() {
      return request.auth.token.email_verified && getViewers().hasAll([request.auth.token.email]);
    }

    function getViewers() {
      return get(/databases/$(database)/documents/admin/roles).data.viewers;
    }

    function areSetsEqual(list1, list2) {
      return list1.hasAll(list2) && list2.hasAll(list1);
    }

    match /stories/{storyId} {
      allow read: if isSignedIn() && isViewer();
      allow update: if isSignedIn() && isViewer() && (
        // Allow updating personsWhoKnow
        areSetsEqual(request.writeFields, ["personsWhoKnow"])
        // Allow updating usersWhoStarred only by adding/removing your own uid
        || (
          areSetsEqual(request.writeFields, ["usersWhoStarred"])
          && (
            // Adding yourself: new list is old list + your uid
            (request.resource.data.usersWhoStarred.hasAll(resource.data.usersWhoStarred)
              && request.resource.data.usersWhoStarred.size() == resource.data.usersWhoStarred.size() + 1
              && request.resource.data.usersWhoStarred.hasAll([request.auth.uid]))
            ||
            // Removing yourself: new list is old list minus your uid
            (resource.data.usersWhoStarred.hasAll(request.resource.data.usersWhoStarred)
              && request.resource.data.usersWhoStarred.size() == resource.data.usersWhoStarred.size() - 1
              && !request.resource.data.usersWhoStarred.hasAll([request.auth.uid]))
          )
        )
      );
      allow create, delete: if false;
    }

    match /persons/{document=**} {
      allow read: if isSignedIn() && isViewer();
      allow create: if isSignedIn() && isViewer()
        && request.resource.data.keys().hasOnly(["name", "group"])
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 100
        && request.resource.data.group is string
        && request.resource.data.group.size() > 0
        && request.resource.data.group.size() <= 50;
      allow update, delete: if false;
    }

    match /camps/{document=**} {
      allow read: if isSignedIn() && isViewer();
      allow create: if isSignedIn() && isViewer()
        && request.resource.data.keys().hasOnly(["group", "number", "rooms"])
        && request.resource.data.group is string
        && request.resource.data.group.size() > 0
        && request.resource.data.group.size() <= 50
        && request.resource.data.number is int
        && request.resource.data.number >= 0;
      allow update: if isSignedIn() && isViewer()
        && request.resource.data.keys().hasOnly(["group", "number", "rooms"]);
      allow delete: if false;
    }

    match /admin/{document=**} {
      allow read, write: if false;
    }
  }
}